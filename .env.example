# ============================================================================
# .env.example
# Variables de entorno para TASD-Federation
# 
# Copiar a .env y modificar según sea necesario
# Por defecto, el docker-compose.yml usa valores hardcodeados
# ============================================================================

# DB2 Instance Password (must match in both services)
DB2INST1_PASSWORD=db2inst1

# DB2 Workload Type
DB2_WORKLOAD=tasdlab

# Federated Server Configuration
FEDERATED_SERVER_NAME=DB2SERVERLOCAL
FEDERATED_SERVER_HOSTNAME=db2_remote
FEDERATED_SERVER_PORT=50000
FEDERATED_SERVER_DBNAME=SAMPLE

# Federated Authentication
FEDERATED_USER=db2inst1
FEDERATED_PASSWORD=db2inst1

# Docker Compose Configuration
COMPOSE_PROJECT_NAME=tasd-federation
COMPOSE_FILE=docker-compose.yml

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Backup Configuration
BACKUP_RETENTION_DAYS=7
BACKUP_FOLDER=./backups

# License (required for DB2 Docker container)
LICENSE=accept

# System Resource Limits (optional, for larger datasets)
# MEMORY_LIMIT=4g
# CPU_LIMIT=2
